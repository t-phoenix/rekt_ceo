# Rekt CEO main backend — auth, NFT info, mint, health (SIWE + Redis).
# Launch Hub / campaigns API runs separately: ../rekt_campaigns/

# Blockchain
CHAIN_ID=11155111
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/
RPC_URL_FALLBACK=https://rpc.sepolia.org
BACKEND_PRIVATE_KEY=

# Contract addresses (from deployment)
MINTER_CONTRACT_ADDRESS=0xccb8a72cd9149F85c74de4d3d2D756782aa338e8
PFP_COLLECTION_ADDRESS=0x953d13825dc4dB8F5a07D90877d1f4626a355bac
MEME_COLLECTION_ADDRESS=0x5a9f7C350A8f69692e36494FCd42e24640aa804d
CEO_TOKEN_ADDRESS=0xA5bcA6252a477C4Eb62cDbabF3C16f7c06b4f741

# IPFS / Pinata
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# Server
PORT=3000
NODE_ENV=production
JWT_SECRET=YOUR_STRONG_SECRET_KEY_MIN_32_CHARS
JWT_EXPIRY=24h

# CORS — comma-separated; backend index also allows rekt.ceo domains in code
CORS_ORIGIN=http://localhost:3001
CORS_ORIGIN_2=http://localhost:5173

# Redis (nonces for SIWE + rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

LOG_LEVEL=info

# If you run the split Launch Hub API (rekt_campaigns), JWT_SECRET here must match that service’s JWT_SECRET.
