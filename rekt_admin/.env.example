#
# Copy to `.env`. Vite only exposes vars prefixed with VITE_ (except NODE_ENV).
#

# Main Rekt backend (nft info, mint, auth nonce/verify) — PORT from that service, often 3000
VITE_API_URL=http://localhost:3000

# Launch Hub / campaigns API — REQUIRED when Launch Hub routes live in rekt_campaigns (default PORT 4047).
# If omitted, Campaigns page falls back to VITE_API_URL (won't work unless those routes are on the main API).
VITE_CAMPAIGN_API_URL=http://localhost:4047

# Optional — pre-fills the admin key in the UI during local dev (same logical value as campaigns server ADMIN_API_KEY)
VITE_ADMIN_API_KEY=
