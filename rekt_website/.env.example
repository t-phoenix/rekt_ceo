# Environment Variables for REKT CEO Website

# WalletConnect Project ID — https://cloud.walletconnect.com/
REACT_APP_WALLETCONNECT_PROJECT_ID=your_project_id_here

#
# Split API URLs (recommended with rekt_campaigns server)
#

# Main backend — SIWE (/api/auth), mint, health, nft info — match rekt_backend PORT (often 3000)
REACT_APP_BACKEND_API_URL=http://localhost:3000

# Launch Hub REST — MUST point at campaigns service when routes are not on the main backend.
# rekt_campaigns defaults to PORT=4047
REACT_APP_CAMPAIGN_API_URL=http://localhost:4047

# Public site URL (sharing, redirects)
REACT_APP_BASE_URL=http://localhost:3001

REACT_APP_SOLANA_TOKEN_MINT=
REACT_APP_SOLANA_RPC_HTTP_URL=https://rpc.ankr.com/solana

REACT_APP_BASE_TOKEN_ADDRESS=0x296ad590f077614d951ccc630e763765d1Ef004f
REACT_APP_BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
REACT_APP_BASE_CHAIN_ID=8453
REACT_APP_BASE_RPC_HTTP_URL=https://mainnet.base.org
