#
# Copy to .env — campaigns / Launch Hub API (rekt_campaigns package root).
# JWT_SECRET must match rekt_backend so SIWE tokens work.
#

# ── Server ───────────────────────────────────────────────────────────────
PORT=4047
NODE_ENV=development
LOG_LEVEL=info

JWT_SECRET=your-32-character-minimum-secret-change-me!!!!!!!!
JWT_EXPIRY=24h

# CORS: origins allowed to call this API (comma-separated).
CORS_ORIGIN=http://localhost:3001
# Optional second origin (preview admin, alternate dev port).
CORS_ORIGIN_2=http://localhost:5173

# Browser base for OAuth redirects back to Launch Hub (?x=ok, etc.).
FRONTEND_URL=http://localhost:3001

REDIS_URL=redis://localhost:6379

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Optional Postgres persistent storage — run migrations/001_schema.sql once.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.fmkccnjamnrcwjtyecas.supabase.co:5432/postgres
DATABASE_PASSWORD=
# ── Rate limits ── (already has sensible defaults in code)

# ── Admin REST (rekt_admin Campaign page) ─────────────────────────────────
ADMIN_API_KEY=

# ── Eligibility & XP tuning ───────────────────────────────────────────────
# Base / eth_call for eligibility + ERC-20 price — also default Base mainnet RPC when chainId=8453 and no RPC_URL_CHAIN_8453.
RPC_URL=https://mainnet.base.org
BASE_RPC_URL=https://mainnet.base.org

# Optional per-chain HTTPS JSON-RPC for **on-chain campaign verify** (`POST /api/campaigns/:id/onchain-verify`).
# If omitted for a chain used in a campaign, verify may throw rpc_not_configured. Base mainnet 8453 falls back to BASE_RPC_URL / RPC_URL above.
# Examples:
# RPC_URL_CHAIN_8453=https://mainnet.base.org
# RPC_URL_CHAIN_84532=https://sepolia.base.org
RPC_URL_CHAIN_8453=
RPC_URL_CHAIN_84532=
RPC_URL_CHAIN_1=
# Ethereum Sepolia (e.g. default campaigns that use chainId 11155111 — dev wallet / contract tooling).
RPC_URL_CHAIN_11155111=

BASE_BALANCE_THRESHOLD_USD=10
ETH_PRICE_USD_FALLBACK=3000

REQUIRE_INVITE_CODE=true
INVITE_XP_INVITEE=75
INVITE_XP_INVITER=200
LAUNCH_HUB_BOOTSTRAP_CODES=

# ── X (Twitter): OAuth + read API ────────────────────────────────────────
X_CLIENT_ID=
X_CLIENT_SECRET=
# Must match the URL registered at X Developer Portal — use Campaign API host:
# http://127.0.0.1:4047/api/identity/x/callback  (adjust port!)
X_REDIRECT_URI=http://127.0.0.1:4047/api/identity/x/callback
X_REQUEST_EMAIL=true
X_FOLLOW_TARGET=rekt_ceo
TWITTERAPI_IO_KEY=
# Minimum seconds between per-wallet tweet-fetch verify attempts (saves quota). Use 0 to disable.
X_MISSION_VERIFY_COOLDOWN_SEC=120
# Throttle auto social re-check during Launch Hub bootstrap (seconds). POST /identity/refresh-social?force bypasses.
SOCIAL_MEMBERSHIP_REFRESH_TTL_SEC=86400

# ── Discord ───────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_REDIRECT_URI=http://localhost:4047/api/identity/discord/callback

# ── Telegram ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
